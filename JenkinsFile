pipeline {
    agent any

    environment {
        IMAGE_NAME = "course_app_backend"
        CONTAINER_NAME = "course_app_backend_ci"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Image') {
            steps {
                sh 'docker build -t $IMAGE_NAME ./backend'
            }
        }

        stage('Stop Old Container') {
            steps {
                sh 'docker rm -f $CONTAINER_NAME || true'
            }
        }

        stage('Run Container') {
            steps {
                sh '''
                docker run -d \
                --name $CONTAINER_NAME \
                -e DATABASE_URL="postgresql://postgres:password@course_app-db-1:5432/courseapp" \
                -e JWT_SECRET="hahaha" \
                $IMAGE_NAME
                '''
            }
        }

        stage('Health Check') {
            steps {
                sh 'sleep 10'
                sh 'docker exec $CONTAINER_NAME curl -f http://localhost:4000/health'
            }
        }
    }

    post {
        success {
            echo 'Deployment Successful'
        }
        failure {
            echo 'Deployment Failed'
        }
    }
}